# Copy this file to .env and fill in your values
# Never commit .env to git

# Your Apify API token — found at https://console.apify.com/account/integrations
APIFY_TOKEN=apify_api_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your actor ID — format is "your-username~indeed-scraper" (use ~ not /)
# Find it on the actor's page in Apify Console under "API" tab
APIFY_ACTOR_ID=your-username~indeed-scraper

# Port the web server listens on (optional, defaults to 3000)
PORT=3000
